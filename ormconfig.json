{
    "type": "better-sqlite3",
    "database": "data/backvynils.sqlite",
    "synchronize": true,
    "logging": false,
    "entities": [
        "src/**/*entity.ts"
    ],
    "migrations": [
        "src/migration/**/*.ts"
    ],
    "subscribers": [
        "src/subscriber/**/*.ts"
    ],
    "cli": {
        "entitiesDir": "src/",
        "migrationsDir": "src/migration",
        "subscribersDir": "src/subscriber"
    }
}